{ config, pkgs, username, ... }:

let
  hmSwayPackage = config.home-manager.users.${username}.wayland.windowManager.sway.package or pkgs.sway;
  swayfxPackage = pkgs.swayfx.override {
    isNixOS = true;
    withGtkWrapper = true;
